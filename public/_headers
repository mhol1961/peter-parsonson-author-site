/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://formspree.io https://api.mailchimp.com;
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/blog/*
  Cache-Control: public, max-age=3600

/books/*
  Cache-Control: public, max-age=7200

/assets/*
  Cache-Control: public, max-age=31536000, immutable
