---
// ContactForm.astro - Contact form with honeypot spam prevention and validation
---

<form
  id="contact-form"
  class="w-full max-w-2xl mx-auto space-y-6"
  action="https://formspree.io/f/YOUR_FORM_ID"
  method="POST"
>
  <!-- Name Field -->
  <div>
    <label for="name" class="block text-sm font-semibold text-cream mb-2">
      Name
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      placeholder="Your full name"
      class="w-full bg-dark-card border border-dark-lighter rounded-lg px-4 py-3 text-gray-100 placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/50 transition-all"
    />
  </div>

  <!-- Email Field -->
  <div>
    <label for="email" class="block text-sm font-semibold text-cream mb-2">
      Email
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder="your@email.com"
      class="w-full bg-dark-card border border-dark-lighter rounded-lg px-4 py-3 text-gray-100 placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/50 transition-all"
    />
  </div>

  <!-- Subject Field -->
  <div>
    <label for="subject" class="block text-sm font-semibold text-cream mb-2">
      Subject
    </label>
    <input
      type="text"
      id="subject"
      name="subject"
      required
      placeholder="What is this about?"
      class="w-full bg-dark-card border border-dark-lighter rounded-lg px-4 py-3 text-gray-100 placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/50 transition-all"
    />
  </div>

  <!-- Message Field -->
  <div>
    <label for="message" class="block text-sm font-semibold text-cream mb-2">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="6"
      placeholder="Your message here..."
      class="w-full bg-dark-card border border-dark-lighter rounded-lg px-4 py-3 text-gray-100 placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/50 transition-all resize-none"
    ></textarea>
  </div>

  <!-- Honeypot spam prevention -->
  <input
    type="text"
    name="website"
    value=""
    style="display:none"
    aria-hidden="true"
    tabindex="-1"
    autocomplete="off"
  />

  <!-- Submit Button -->
  <div class="flex gap-4">
    <button
      type="submit"
      class="px-8 py-3 bg-accent hover:bg-accent-light text-white font-semibold rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-accent/50"
    >
      Transmit Message
    </button>
    <button
      type="reset"
      class="px-8 py-3 bg-dark-lighter hover:bg-dark-lighter/80 text-gray-300 hover:text-cream font-semibold rounded-lg transition-all duration-200"
    >
      Clear
    </button>
  </div>

  <!-- Status Messages -->
  <div id="form-status" class="hidden mt-4 p-4 rounded-lg text-sm font-medium"></div>
</form>

<script>
  const form = document.getElementById('contact-form');
  const statusDiv = document.getElementById('form-status');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);

      // Client-side validation
      const name = formData.get('name')?.toString().trim();
      const email = formData.get('email')?.toString().trim();
      const message = formData.get('message')?.toString().trim();
      const honeypot = formData.get('website')?.toString().trim();

      // Check honeypot
      if (honeypot) {
        statusDiv.textContent = 'Form submission blocked.';
        statusDiv.className = 'block mt-4 p-4 rounded-lg text-sm font-medium bg-accent/20 text-accent-light';
        return;
      }

      if (!name || !email || !message) {
        statusDiv.textContent = 'Please fill in all required fields.';
        statusDiv.className = 'block mt-4 p-4 rounded-lg text-sm font-medium bg-accent/20 text-accent-light';
        return;
      }

      if (!email.includes('@')) {
        statusDiv.textContent = 'Please enter a valid email address.';
        statusDiv.className = 'block mt-4 p-4 rounded-lg text-sm font-medium bg-accent/20 text-accent-light';
        return;
      }

      try {
        // Attempt to submit to Formspree
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            Accept: 'application/json'
          }
        });

        if (response.ok) {
          statusDiv.textContent = 'Thank you! Your message has been sent.';
          statusDiv.className = 'block mt-4 p-4 rounded-lg text-sm font-medium bg-primary/20 text-primary-light';
          form.reset();

          setTimeout(() => {
            statusDiv.classList.add('hidden');
          }, 5000);
        } else {
          statusDiv.textContent = 'Something went wrong. Please try again.';
          statusDiv.className = 'block mt-4 p-4 rounded-lg text-sm font-medium bg-accent/20 text-accent-light';
        }
      } catch (error) {
        statusDiv.textContent = 'Network error. Please check your connection and try again.';
        statusDiv.className = 'block mt-4 p-4 rounded-lg text-sm font-medium bg-accent/20 text-accent-light';
      }
    });
  }
</script>
