---
// Footer.astro - Dark cinematic footer with sharp edges, bold typography, and dramatic styling
const base = import.meta.env.BASE_URL;
---

<footer class="section-darker border-t-4 border-accent/30 py-16 md:py-20 mt-20 relative">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Main Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16 pb-16 border-b border-gray-800/50">
      <!-- Logo/Brand Section -->
      <div class="md:col-span-1">
        <h3 class="text-2xl font-heading font-black text-cream uppercase tracking-tighter mb-6 leading-tight">
          PETER<br/>P.
        </h3>
        <p class="text-gray-300 text-sm leading-relaxed mb-6 font-light">
          Military thriller author. Stories grounded in declassified history, real EMP science, and twenty-two years of research.
        </p>
        <div class="inline-block border border-gray-700 px-4 py-2">
          <p class="text-xs text-primary uppercase font-bold tracking-widest">
            USCG Authors Program
          </p>
        </div>
      </div>

      <!-- Quick Navigation -->
      <div>
        <h4 class="text-xs font-heading font-black text-cream uppercase tracking-widest mb-6">
          Navigation
        </h4>
        <ul class="space-y-3">
          <li><a href={base} class="text-gray-400 hover:text-cream transition-colors text-sm uppercase tracking-wide font-semibold">Home</a></li>
          <li><a href={`${base}/about`} class="text-gray-400 hover:text-cream transition-colors text-sm uppercase tracking-wide font-semibold">About Peter P.</a></li>
          <li><a href={`${base}/books`} class="text-gray-400 hover:text-cream transition-colors text-sm uppercase tracking-wide font-semibold">The Book</a></li>
          <li><a href={`${base}/blog`} class="text-gray-400 hover:text-cream transition-colors text-sm uppercase tracking-wide font-semibold">Dispatches</a></li>
          <li><a href={`${base}/contact`} class="text-gray-400 hover:text-cream transition-colors text-sm uppercase tracking-wide font-semibold">Contact</a></li>
        </ul>
      </div>

      <!-- Newsletter Signup -->
      <div>
        <h4 class="text-xs font-heading font-black text-cream uppercase tracking-widest mb-6">
          Intel Updates
        </h4>
        <p class="text-gray-400 text-sm mb-4 leading-relaxed">
          Exclusive updates. No spam. No noise.
        </p>
        <form class="space-y-3" onsubmit="event.preventDefault();">
          <input
            type="email"
            placeholder="Enter email"
            class="w-full bg-gray-900/50 border border-gray-700 px-4 py-3 text-sm text-cream placeholder-gray-600 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/50 transition-all"
          />
          <button
            type="submit"
            class="btn-primary w-full text-center"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Social & Copyright -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Social Icons - SVG style -->
      <div class="flex gap-6">
        <a
          href="#"
          aria-label="Instagram"
          title="Instagram"
          class="group"
        >
          <svg class="w-5 h-5 text-gray-500 group-hover:text-primary transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.35 8.6h-2.1c-.2-1.4-.9-2.6-2.2-3.4-1.3-.8-2.9-.8-4.2 0-1.3.8-2.1 2-2.2 3.4H6.65c.05-1.8 1.2-3.4 2.9-4.5 1.7-1 3.8-1 5.5 0 1.7 1.1 2.85 2.7 2.9 4.5zm-4.5 8.5c-1.8 0-3.4-.8-4.5-2.2-1.1-1.4-1.3-3.2-.7-4.8.6-1.6 2-2.7 3.7-2.9h.05c1.4 0 2.8.6 3.7 1.6.9 1 1.4 2.3 1.4 3.7 0 1.8-.8 3.4-2.2 4.5-1.4 1.1-3.1 1.3-4.9.7z"/>
          </svg>
        </a>
        <a
          href="#"
          aria-label="X / Twitter"
          title="X / Twitter"
          class="group"
        >
          <svg class="w-5 h-5 text-gray-500 group-hover:text-primary transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.606l-5.175-6.76-5.944 6.76H2.556l7.746-8.973L1.25 2.25h6.74l4.759 6.285L17.564 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a
          href="#"
          aria-label="Facebook"
          title="Facebook"
          class="group"
        >
          <svg class="w-5 h-5 text-gray-500 group-hover:text-primary transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-gray-500 text-xs uppercase tracking-wider text-center md:text-right">
        &copy; {new Date().getFullYear()} Peter P. &mdash; The John Hunter Series. All rights reserved.
      </p>
      <p class="mil-text mt-4 text-center">Dark Territory Protocol — All Channels Monitored</p>
    </div>
  </div>
</footer>
