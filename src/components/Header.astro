---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const navLinks = [
  { label: 'Home', href: base },
  { label: 'About', href: `${base}about` },
  { label: 'Books', href: `${base}books` },
  { label: 'Blog', href: `${base}blog` },
  { label: 'Contact', href: `${base}contact` }
];
function isActive(href: string): boolean {
  if (href === base) return currentPath === base || currentPath === base + '/';
  return currentPath.startsWith(href);
}
---

<!-- Top accent strip -->
<div class="accent-strip hidden md:block">
  <a href={`${base}books`} class="hover:text-gray-200 transition-colors">
    THE TEMPEST TOSS — COMING FALL 2026
  </a>
</div>

<header class="sticky top-0 z-50 border-b border-white/5" style="background: rgba(10, 14, 26, 0.95); backdrop-filter: blur(12px);">
  <nav class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <!-- Logo Wordmark -->
    <a href={base} class="flex flex-col items-start group">
      <span class="text-xl md:text-2xl font-heading font-black text-cream tracking-[0.15em] group-hover:text-white transition-colors">
        P.S. PARSONSON
      </span>
      <div class="h-px w-8 bg-teal-600/50 my-1"></div>
      <span class="text-[0.5rem] uppercase tracking-[0.3em] text-gray-400 font-semibold" style="font-family: 'Space Grotesk', 'Inter', sans-serif;">
        Military Thriller Author
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-xs uppercase tracking-[0.25em] hover:text-white transition-colors duration-300 font-semibold ${isActive(link.href) ? 'text-accent' : 'text-gray-400'}`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Social Icons (Desktop) -->
    <div class="hidden lg:flex items-center gap-4">
      <a href="https://x.com/Hawkeye45691" target="_blank" rel="noopener noreferrer" aria-label="X/Twitter" class="text-gray-500 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden" style="max-height: 0; overflow: hidden; transition: max-height 0.4s ease;">
    <div class="px-6 py-6 flex flex-col gap-5 border-t border-white/5" style="background: rgba(10, 14, 26, 0.98);">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-sm uppercase tracking-[0.25em] hover:text-white transition-colors font-semibold ${isActive(link.href) ? 'text-accent' : 'text-gray-300'}`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        if (open) {
          menu.style.maxHeight = '0';
          setTimeout(() => menu.classList.add('hidden'), 400);
        } else {
          menu.classList.remove('hidden');
          menu.style.maxHeight = menu.scrollHeight + 'px';
        }
      });
    }
  });
</script>
