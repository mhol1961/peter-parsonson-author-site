---
// NewsletterSignup.astro - Mailchimp email signup
---

<form
  id="newsletter-form"
  class="w-full max-w-lg mx-auto"
  action="https://example.us1.list-manage.com/subscribe/post?u=YOUR_LIST_ID&id=YOUR_FORM_ID"
  method="POST"
>
  <div class="flex flex-col sm:flex-row gap-3">
    <input
      type="email"
      name="EMAIL"
      placeholder="Enter your email"
      required
      class="flex-1 px-5 py-4 text-white text-sm"
      style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);"
    />
    <button type="submit" class="btn-primary text-center whitespace-nowrap">
      Subscribe
    </button>
  </div>

  <!-- Honeypot -->
  <input type="text" name="b_YOUR_LIST_ID_YOUR_FORM_ID" value="" style="display:none" aria-hidden="true" tabindex="-1" />

  <p class="text-gray-600 text-xs mt-4 text-center">
    We respect your privacy. Unsubscribe at any time.
  </p>

  <div id="form-message" class="mt-4 hidden text-center text-sm"></div>
</form>

<script>
  const form = document.getElementById('newsletter-form');
  const msg = document.getElementById('form-message');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = new FormData(form).get('EMAIL');
      if (!email || !String(email).includes('@')) {
        msg.textContent = 'Please enter a valid email address.';
        msg.className = 'mt-4 text-center text-sm text-red-400 block';
        return;
      }
      try {
        await fetch(form.action, { method: 'POST', body: new FormData(form), mode: 'no-cors' });
        msg.textContent = 'Thank you for subscribing!';
        msg.className = 'mt-4 text-center text-sm text-emerald-400 block';
        form.reset();
        setTimeout(() => msg.classList.add('hidden'), 5000);
      } catch {
        msg.textContent = 'Something went wrong. Please try again.';
        msg.className = 'mt-4 text-center text-sm text-red-400 block';
      }
    });
  }
</script>
