---
// NewsletterSignup.astro — "Intel Updates" signup.
// Captures full name (required), email (required), and optional phone via
// Formspree (same endpoint as the contact form). A hidden `signup_type`
// field labels each submission in the email body so newsletter signups are
// easy to tell apart from contact messages. Multi-instance safe (handlers
// bind to every .newsletter-form on the page).
const inputClass =
  'w-full bg-gray-900/50 border border-gray-700 px-4 py-3 text-sm text-cream placeholder-gray-600 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/50 transition-all';
---

<form class="newsletter-form w-full space-y-3" action="https://formspree.io/f/mrewgqrq" method="POST">
  <!-- Labels this submission in the notification body -->
  <input type="hidden" name="signup_type" value="Intel Updates Newsletter" />

  <input type="text" name="name" required placeholder="Full name" class={inputClass} autocomplete="name" />
  <input type="email" name="email" required placeholder="Email address" class={inputClass} autocomplete="email" />

  <!-- Honeypot: Formspree discards submissions where this is filled -->
  <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <button type="submit" class="btn-primary w-full text-center">Subscribe</button>

  <p class="text-gray-600 text-xs text-center">We respect your privacy. Unsubscribe at any time.</p>
  <div class="newsletter-msg hidden text-center text-sm"></div>
</form>

<script>
  document.querySelectorAll('.newsletter-form').forEach((form) => {
    const msg = form.querySelector('.newsletter-msg');
    const setMsg = (text, ok) => {
      msg.textContent = text;
      msg.className = `newsletter-msg mt-2 text-center text-sm block ${ok ? 'text-emerald-400' : 'text-red-400'}`;
    };
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      if (data.get('_gotcha')) return; // bot
      const name = (data.get('name') || '').toString().trim();
      const email = (data.get('email') || '').toString().trim();
      if (!name || !email.includes('@')) {
        setMsg('Please enter your name and a valid email address.', false);
        return;
      }
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          setMsg("You're on the list. Watch your inbox for dispatches.", true);
          form.reset();
          setTimeout(() => msg.classList.add('hidden'), 6000);
        } else {
          setMsg('Something went wrong. Please try again.', false);
        }
      } catch {
        setMsg('Network error. Please check your connection and try again.', false);
      }
    });
  });
</script>
