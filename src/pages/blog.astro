---
// Blog page — "Field Dispatches" listing, driven by the blog content collection.
import BaseLayout from '@layouts/BaseLayout.astro';
import NewsletterSignup from '@components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

const img = (p) => `${base}${p.replace(/^\//, '')}`;
const longDate = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const tickerDate = (d) => d.toLocaleDateString('en-CA').replace(/-/g, '.'); // YYYY.MM.DD

// Real category counts (no fabrication)
const counts = {};
for (const p of posts) counts[p.data.category] = (counts[p.data.category] || 0) + 1;
const categories = Object.entries(counts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="Field Dispatches — P.S. Parsonson Author Blog"
  description="Research notes on EMP science, Cold War history, and the craft of military fiction from P.S. Parsonson, author of The Tempest Toss."
  type="website"
>
  <!-- Hero Section - Military Communications Terminal -->
  <section class="relative overflow-hidden" style={`min-height: 60vh; display: flex; align-items: center; background-image: linear-gradient(135deg, rgba(10, 14, 26, 0.88) 0%, rgba(6, 10, 20, 0.85) 100%), url('${base}images/blog-hero-bg.jpg'); background-size: cover; background-position: center; background-attachment: fixed;`}>
    <div class="absolute inset-0 z-0" style="background: linear-gradient(rgba(13, 148, 136, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(13, 148, 136, 0.03) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="scan-lines absolute inset-0 z-0"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="teal-divider mb-6"></div>
          <p class="section-label">Field Dispatches</p>
          <h1 class="font-heading font-black text-cream leading-[0.95] mb-6 text-shadow-heavy">
            <span class="block text-5xl md:text-6xl lg:text-7xl uppercase tracking-tighter">Field</span>
            <span class="block text-5xl md:text-6xl lg:text-7xl uppercase tracking-tighter text-accent">Dispatches</span>
          </h1>
          <p class="text-xl text-gray-300 max-w-xl leading-relaxed">
            Research notes on EMP science, Cold War history, and the craft of military fiction, from the desk of P.S. Parsonson.
          </p>
        </div>

        <!-- Dispatch Terminal (real latest posts) -->
        <div class="flex flex-col justify-center lg:items-end">
          <div class="dispatch-terminal w-full lg:max-w-[360px]">
            <div class="dispatch-terminal-header">/// Latest Transmissions</div>
            <div class="dispatch-ticker-wrapper">
              <div class="dispatch-ticker">
                {posts.slice(0, 3).map((p) => (
                  <a href={`${base}blog/${p.id}`} class="dispatch-item block hover:text-accent transition-colors">
                    <span class="dispatch-timestamp">{tickerDate(p.data.pubDate)}</span>
                    {p.data.title}
                  </a>
                ))}
              </div>
            </div>
          </div>
          <p class="mil-text mt-3 text-center lg:text-right">Comms Protocol: Secure // Encrypted</p>
        </div>
      </div>
    </div>
  </section>

  <div class="accent-strip"></div>

  <!-- Featured Article -->
  {featured && (
    <section class="section-dark py-16 md:py-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-12 items-start">
          <div class="md:col-span-1 relative">
            <a href={`${base}blog/${featured.id}`} class="block aspect-square border-2 border-red-600/30 overflow-hidden group">
              <img src={img(featured.data.image)} alt={featured.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="eager" width="600" height="600" />
            </a>
          </div>
          <div class="md:col-span-2">
            <div class="inline-flex items-center gap-2 mb-4">
              <span class="sector-tag">{featured.data.category}</span>
              <span class="text-xs uppercase tracking-widest text-gray-500 font-bold ml-2">Featured</span>
            </div>
            <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter text-cream mb-4">
              <a href={`${base}blog/${featured.id}`} class="hover:text-accent transition-colors">{featured.data.title}</a>
            </h2>
            <p class="text-gray-400 text-sm uppercase tracking-widest mb-6 font-semibold">{longDate(featured.data.pubDate)} • {featured.data.readTime}</p>
            <p class="text-gray-300 text-lg leading-relaxed mb-8">{featured.data.excerpt}</p>
            <a href={`${base}blog/${featured.id}`} class="btn-primary hover:shadow-lg hover:shadow-red-600/50">Read Full Article</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Article Grid -->
  <section class="section-darker py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="section-label">Field Dispatches</p>
        <h2 class="text-4xl font-black uppercase tracking-tighter text-cream mb-4">All Articles</h2>
        <div class="h-1 w-16 bg-red-600"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {rest.map((p) => (
          <article class="section-card border border-red-600/30 overflow-hidden hover:border-red-600/60 transition-all duration-300 group flex flex-col">
            <a href={`${base}blog/${p.id}`} class="aspect-video overflow-hidden relative border-b border-red-600/20 block">
              <img src={img(p.data.image)} alt={p.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" width="640" height="360" />
            </a>
            <div class="p-8 flex-1 flex flex-col">
              <div class="flex items-center gap-3 mb-4">
                <span class="sector-tag">{p.data.category}</span>
                <span class="text-gray-600">•</span>
                <span class="text-xs text-gray-500">{p.data.readTime}</span>
              </div>
              <h3 class="text-2xl font-black uppercase tracking-tight text-cream mb-3 group-hover:text-red-500 transition-colors">
                <a href={`${base}blog/${p.id}`}>{p.data.title}</a>
              </h3>
              <p class="text-gray-300 text-sm leading-relaxed flex-1 mb-6">{p.data.excerpt}</p>
              <a href={`${base}blog/${p.id}`} class="inline-flex items-center gap-2 text-red-500 hover:text-red-400 transition-colors font-black uppercase text-xs tracking-wider">
                Read More <span>→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories + Newsletter -->
  <section class="py-16 md:py-20 border-t border-white/5" style="background: linear-gradient(180deg, #0d1117 0%, #0a0e1a 100%);">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <h3 class="text-xl font-black uppercase tracking-tight text-cream mb-6 pb-3 border-b-2 border-red-600">Categories</h3>
          <ul class="space-y-3">
            {categories.map(([name, count]) => (
              <li class="flex items-center justify-between text-gray-400 uppercase text-sm tracking-wider font-semibold">
                <span>{name}</span>
                <span class="text-gray-600">{count}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-xl font-black uppercase tracking-tight text-cream mb-6 pb-3 border-b-2 border-teal-600">Intel Updates</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6">Mission briefings, release intel, and behind-the-scenes dispatches, delivered to your inbox. No spam.</p>
          <NewsletterSignup />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
