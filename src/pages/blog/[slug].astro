---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;

const img = (p) => `${base}${p.replace(/^\//, '')}`;
const dateStr = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const all = await getCollection('blog', ({ data }) => !data.draft);
const related = all
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title={`${post.data.title} | P.S. Parsonson`}
  description={post.data.description}
  type="article"
  publishDate={post.data.pubDate.toISOString()}
  ogImage={post.data.image}
>
  <div class="read-progress" id="read-progress"></div>

  <!-- Article hero -->
  <section
    class="relative overflow-hidden"
    style={`min-height: 52vh; display:flex; align-items:flex-end; background-image: linear-gradient(180deg, rgba(10,14,26,0.45) 0%, rgba(10,14,26,0.94) 100%), url('${img(post.data.image)}'); background-size:cover; background-position:center;`}
  >
    <div class="max-w-3xl mx-auto px-6 pb-14 relative z-10 w-full">
      <a href={`${base}blog`} class="text-xs uppercase tracking-[0.3em] text-gray-300 hover:text-accent transition-colors font-bold">&larr; Field Dispatches</a>
      <p class="text-xs uppercase tracking-[0.3em] text-accent font-bold mt-6 mb-4">{post.data.category}</p>
      <h1 class="font-heading font-black text-cream text-4xl md:text-5xl leading-tight text-shadow-heavy">{post.data.title}</h1>
      <div class="flex flex-wrap items-center gap-4 mt-6 text-sm text-gray-400">
        <span>By P.S. Parsonson</span>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <time datetime={post.data.pubDate.toISOString()}>{dateStr}</time>
        <span class="w-1 h-1 rounded-full bg-gray-600"></span>
        <span>{post.data.readTime}</span>
      </div>
    </div>
  </section>

  <!-- Article body -->
  <article class="section-dark py-16 md:py-20">
    <div class="blog-prose max-w-3xl mx-auto px-6">
      <Content />
    </div>

    <!-- CTA -->
    <div class="max-w-3xl mx-auto px-6 mt-16">
      <div class="section-card border-l-4 border-accent p-8">
        <h2 class="text-2xl font-heading font-black text-cream uppercase tracking-tight mb-3">The Tempest Toss arrives Fall 2026</h2>
        <p class="text-gray-300 mb-6">Book 1 of the John Hunter series. Real EMP science, Cold War history, and twenty-two years of research.</p>
        <div class="flex flex-wrap gap-4">
          <a href={`${base}books`} class="btn-primary">See the Book</a>
          <a href={`${base}blog`} class="btn-secondary">More Dispatches</a>
        </div>
      </div>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div class="max-w-3xl mx-auto px-6 mt-16">
        <h2 class="text-xs uppercase tracking-[0.3em] text-accent font-bold mb-6">More Dispatches</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {related.map((p) => (
            <a href={`${base}blog/${p.id}`} class="section-card group block overflow-hidden">
              <div class="aspect-[16/9] overflow-hidden">
                <img src={img(p.data.image)} alt={p.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" width="640" height="360" />
              </div>
              <div class="p-5">
                <p class="text-[10px] uppercase tracking-[0.25em] text-accent font-bold mb-2">{p.data.category}</p>
                <h3 class="font-heading font-bold text-cream group-hover:text-accent transition-colors leading-snug">{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>

  <style>
    /* Reading progress bar */
    .read-progress { position: fixed; top: 0; left: 0; height: 3px; width: 0%; z-index: 60; background: linear-gradient(90deg, #0d9488, #DC2626); transition: width .08s linear; }

    .blog-prose :global(p) { color: #cbd2dc; line-height: 1.85; margin: 0 0 1.6rem; font-size: 1.08rem; }
    /* Lead paragraph + drop cap */
    .blog-prose :global(p:first-of-type) { font-size: 1.2rem; color: #dde3ea; }
    .blog-prose :global(p:first-of-type)::first-letter { float: left; font-family: 'Playfair Display', serif; font-weight: 800; font-size: 4.2rem; line-height: .72; padding: .4rem .55rem 0 0; color: #DC2626; }
    /* Section headings as accented dividers */
    .blog-prose :global(h2) { color: #F5F0E8; font-family: 'Playfair Display', serif; font-weight: 800; font-size: 1.8rem; line-height: 1.2; margin: 3rem 0 1.1rem; padding-top: 1.6rem; border-top: 1px solid rgba(255,255,255,.08); position: relative; }
    .blog-prose :global(h2)::before { content: ''; position: absolute; top: -1px; left: 0; width: 48px; height: 3px; background: #DC2626; }
    .blog-prose :global(h3) { color: #F5F0E8; font-weight: 700; font-size: 1.3rem; margin: 2rem 0 .75rem; }
    .blog-prose :global(a) { color: #2dd4bf; text-decoration: underline; text-underline-offset: 3px; transition: color .2s; }
    .blog-prose :global(a:hover) { color: #5eead4; }
    .blog-prose :global(strong) { color: #F5F0E8; font-weight: 700; }
    .blog-prose :global(em) { color: #e7d9c4; }
    .blog-prose :global(ul), .blog-prose :global(ol) { color: #cbd2dc; margin: 0 0 1.6rem 1.25rem; line-height: 1.85; }
    .blog-prose :global(li) { margin-bottom: .5rem; }
    /* Pull quote */
    .blog-prose :global(blockquote) { margin: 2.6rem 0; padding: .25rem 0 .25rem 1.6rem; border-left: 3px solid #DC2626; }
    .blog-prose :global(blockquote p) { font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.55rem; line-height: 1.4; color: #F5F0E8; margin: 0; }
    /* Field Note callout */
    .blog-prose :global(.field-note) { margin: 2.6rem 0; padding: 1.5rem 1.75rem; background: rgba(13,148,136,.06); border: 1px solid rgba(13,148,136,.25); border-left: 4px solid #0d9488; color: #cbd2dc; font-size: 1rem; line-height: 1.7; }
    .blog-prose :global(.field-note-label) { display: block; font-size: .7rem; letter-spacing: .25em; text-transform: uppercase; color: #2dd4bf; font-weight: 800; margin-bottom: .55rem; }
  </style>

  <script>
    const bar = document.getElementById('read-progress');
    const update = () => {
      const el = document.documentElement;
      const max = el.scrollHeight - el.clientHeight;
      if (bar) bar.style.width = (max > 0 ? (el.scrollTop / max) * 100 : 0) + '%';
    };
    document.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  </script>
</BaseLayout>
